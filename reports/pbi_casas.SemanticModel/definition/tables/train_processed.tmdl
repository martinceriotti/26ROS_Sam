table train_processed
	lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890

	measure 'N Propiedades' = COUNTROWS(train_processed)
		formatString: #,0
		lineageTag: a1000002-0000-0000-0000-000000000001

	measure 'Precio Mediano' = MEDIAN(train_processed[lastSoldPrice_hpi_adjusted])
		formatString: "$#,##0"
		lineageTag: a1000002-0000-0000-0000-000000000002

	measure 'Precio Promedio' = AVERAGE(train_processed[lastSoldPrice_hpi_adjusted])
		formatString: "$#,##0"
		lineageTag: a1000002-0000-0000-0000-000000000003

	measure 'Precio Máximo' = MAX(train_processed[lastSoldPrice_hpi_adjusted])
		formatString: "$#,##0"
		lineageTag: a1000002-0000-0000-0000-000000000004

	measure 'Precio Mínimo' = MIN(train_processed[lastSoldPrice_hpi_adjusted])
		formatString: "$#,##0"
		lineageTag: a1000002-0000-0000-0000-000000000005

	measure 'Precio Mediano por ft2' =
			VAR avgArea = AVERAGE(train_processed[livingArea])
			VAR medPrice = MEDIAN(train_processed[lastSoldPrice_hpi_adjusted])
			RETURN IF(avgArea > 0, DIVIDE(medPrice, avgArea), BLANK())
		formatString: "$#,##0.00"
		lineageTag: d7edecac-615e-43d4-9d86-fc1c52894e97

	measure '% Con Pool' =
			DIVIDE(
			    CALCULATE(COUNTROWS(train_processed), train_processed[has_pool] = 1),
			    COUNTROWS(train_processed)
			)
			formatString: 0.0%
			lineageTag: a1000002-0000-0000-0000-000000000007
		lineageTag: 6d06b551-7431-463e-8a76-db1f52e59207

	measure '% Con Waterfront' =
			DIVIDE(
			    CALCULATE(COUNTROWS(train_processed), train_processed[has_waterfront] = 1),
			    COUNTROWS(train_processed)
			)
			formatString: 0.0%
			lineageTag: a1000002-0000-0000-0000-000000000008
		lineageTag: 3f04f8bb-1618-4b88-9bc1-de98636396db

	measure '% Con Garage' =
			DIVIDE(
			    CALCULATE(COUNTROWS(train_processed), train_processed[has_garage] = 1),
			    COUNTROWS(train_processed)
			)
			formatString: 0.0%
			lineageTag: a1000002-0000-0000-0000-000000000009
		lineageTag: bdd5f72e-f3fd-4761-9e87-0a8bfd08db21

	measure '% Con HOA' =
			DIVIDE(
			    CALCULATE(COUNTROWS(train_processed), train_processed[has_hoa] = 1),
			    COUNTROWS(train_processed)
			)
			formatString: 0.0%
			lineageTag: a1000002-0000-0000-0000-000000000010
		lineageTag: b2c24f22-e1de-4838-adbc-bf3703b7db64

	measure 'School Rating Promedio' = AVERAGE(train_processed[avg_school_rating])
		formatString: 0.0
		lineageTag: a1000002-0000-0000-0000-000000000011

	measure 'Área Habitable Mediana (ft2)' = MEDIAN(train_processed[livingArea])
		formatString: #,0
		lineageTag: a1000002-0000-0000-0000-000000000012

	measure 'Precio Mediano Waterfront vs No' =
			VAR conWater = CALCULATE(MEDIAN(train_processed[lastSoldPrice_hpi_adjusted]), train_processed[has_waterfront] = 1)
			VAR sinWater = CALCULATE(MEDIAN(train_processed[lastSoldPrice_hpi_adjusted]), train_processed[has_waterfront] = 0)
			RETURN DIVIDE(conWater - sinWater, sinWater)
			formatString: 0.0%
			lineageTag: a1000002-0000-0000-0000-000000000013
		lineageTag: 3b3a09f7-58f5-4f1c-a2cc-feadd57710e5

