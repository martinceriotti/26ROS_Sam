	partition train_processed = m
		mode: import
		source =
				let
				    Origen = Csv.Document(File.Contents("C:\Users\SBI\Downloads\participant\data\tabular\train_processed.csv"),[Delimiter=",", Columns=46, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Encabezados promovidos" = Table.PromoteHeaders(Origen, [PromoteAllScalars=true]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(#"Encabezados promovidos",{
				        {"zpid", Int64.Type},
				        {"lastSoldPrice_hpi_adjusted", type number},
				        {"log_price", type number},
				        {"description", type text},
				        {"bedrooms", type number},
				        {"bathrooms", type number},
				        {"livingArea", type number},
				        {"yearBuilt", type number},
