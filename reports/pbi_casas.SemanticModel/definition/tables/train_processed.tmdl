				        {"min_school_distance", type number},
				        {"has_hoa", Int64.Type},
				        {"hoa_fee_monthly", type number},
				        {"has_pool", Int64.Type},
				        {"has_garage", Int64.Type},
				        {"has_waterfront", Int64.Type},
				        {"tag_price_cut", Int64.Type},
				        {"tag_new_construction", Int64.Type},
				        {"tag_foreclosure", Int64.Type},
				        {"property_age", type number},
				        {"bath_to_bed_ratio", type number},
				        {"log_living_area", type number},
